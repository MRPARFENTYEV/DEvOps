# Инвентарь Kubespray. Скопируй в hosts.yml и подставь IP из `terraform output ansible_hosts`
# (или сгенерируй автоматически: ./scripts/gen-inventory.sh).
# hosts.yml в git НЕ коммитится.
all:
  hosts:
    k8s-master:
      ansible_host: MASTER_PUBLIC_IP    # публичный IP master-ноды
      ip: MASTER_PRIVATE_IP             # внутренний IP
      access_ip: MASTER_PRIVATE_IP
    k8s-worker-1:
      ansible_host: WORKER1_PUBLIC_IP
      ip: WORKER1_PRIVATE_IP
      access_ip: WORKER1_PRIVATE_IP
    k8s-worker-2:
      ansible_host: WORKER2_PUBLIC_IP
      ip: WORKER2_PRIVATE_IP
      access_ip: WORKER2_PRIVATE_IP
  children:
    kube_control_plane:
      hosts:
        k8s-master:
    etcd:
      hosts:
        k8s-master:
    kube_node:
      hosts:
        k8s-worker-1:
        k8s-worker-2:
    k8s_cluster:
      children:
        kube_control_plane:
        kube_node:
